  "components": {
    "schemas": {
      "ApplyReferralRequest": {
        "required": [
          "referralCode"
        ],
        "type": "object",
        "properties": {
          "referralCode": {
            "type": "string"
          }
        }
      },
      "FingerprintRequest": {
        "required": [
          "strong",
          "weak"
        ],
        "type": "object",
        "properties": {
          "strong": {
            "type": [
              "null",
              "string"
            ]
          },
          "weak": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "RefreshTokenRequest": {
        "required": [
          "refreshToken"
        ],
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string"
          }
        }
      },
      "RegisterFcmTokenRequest": {
        "required": [
          "token",
          "platform"
        ],
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "platform": {
            "type": "string"
          }
        }
      },
      "SendOtpRequest": {
        "required": [
          "phoneNumber"
        ],
        "type": "object",
        "properties": {
          "phoneNumber": {
            "type": "string"
          }
        }
      },
      "VerifyOtpRequest": {
        "required": [
          "phoneNumber",
          "otpCode",
          "referralCode"
        ],
        "type": "object",
        "properties": {
          "phoneNumber": {
            "type": "string"
          },
          "otpCode": {
            "type": "string"
          },
          "referralCode": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "WithdrawalRequest": {
        "required": [
          "amount",
          "bankCode",
          "accountNumber",
          "accountHolder"
        ],
        "type": "object",
        "properties": {
          "amount": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "bankCode": {
            "type": "string"
          },
          "accountNumber": {
            "type": "string"
          },
          "accountHolder": {
            "type": "string"
          }
        }
      }
    }
